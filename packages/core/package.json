{
  "name": "@effect-vue/core",
  "type": "module",
  "version": "0.1.0",
  "description": "Vue 3 bindings for Effect-TS — atoms, runtime, composables",
  "author": "Danny Ahn",
  "license": "MIT",
  "homepage": "https://github.com/dannydevs/effect-vue#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dannydevs/effect-vue.git",
    "directory": "packages/core"
  },
  "keywords": ["effect", "effect-ts", "vue", "vue3", "reactivity", "composables"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["README.md", "dist", "src"],
  "scripts": {
    "build": "tsdown && vue-tsc -p tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "vue-tsc --noEmit && vue-tsc -p tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "effect": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "effect": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
